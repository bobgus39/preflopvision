# ── Frontend (Vite build-time) ────────────────────────────────────────────────
# Leave empty in development — Vite proxy forwards /api/* to localhost:3001
# In production (Railway) this is not needed; API is same-origin
VITE_API_URL=

# ── Backend (server/.env in development / Railway Variables in production) ────

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Stripe Webhook Signing Secret — https://dashboard.stripe.com/webhooks
# Must start with whsec_
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create products in Stripe dashboard first
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# Your deployed frontend URL (used for Stripe redirect URLs)
FRONTEND_URL=https://www.preflopvision.com

# PostgreSQL — added automatically by Railway when you add the PostgreSQL addon
# For local dev: install PostgreSQL and create a database
DATABASE_URL=postgresql://user:password@localhost:5432/preflopvision

# Server port (Railway sets this automatically)
PORT=3001

# Set to 'production' in Railway Variables
NODE_ENV=production
